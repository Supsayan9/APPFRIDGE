{
  "name": "appfridge-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build -w @appfridge/shared",
    "dev:server": "npm run dev -w @appfridge/server",
    "dev:mobile": "npm --prefix ./apps/mobile run start",
    "build": "npm run build -w @appfridge/shared && npm run build -w @appfridge/server",
    "test": "npm run test -w @appfridge/shared"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/react": "~19.1.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-notifications": "~0.32.17",
    "expo-status-bar": "~3.0.9",
    "react-native": "0.81.5"
  }
}
