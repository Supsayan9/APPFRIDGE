{
  "name": "appfridge-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build -w @appfridge/shared",
    "dev:server": "npm run dev -w @appfridge/server",
    "dev:mobile": "npm run start -w @appfridge/mobile",
    "build": "npm run build -w @appfridge/shared && npm run build -w @appfridge/server",
    "test": "npm run test -w @appfridge/shared"
  }
}
