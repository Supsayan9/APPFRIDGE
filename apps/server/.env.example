PORT=4000
CLIENT_ORIGIN=*
DATABASE_PATH=./appfridge.db
EXPO_ACCESS_TOKEN=
# Pexels — фотосток (не OpenAI). Для AI-рецептів не використовується.
PEXELS_KEY=
# Штрихкоди: Open Food Facts + Open Beauty Facts + Open Pet Food Facts (онлайн, кеш у SQLite products)
# Рецепти AI (ChatGPT API): https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Альтернативні назви того самого ключа (Bearer до api.openai.com):
AI_API_KEY=
APIFREE_KEY=
# Для OpenAI-compatible провайдерів можна вказати базовий URL (без /chat/completions):
# OPENAI_BASE_URL=https://api.apifree.ai
# OPENAI_BASE_URL=https://openrouter.ai/api
# Таймаут запиту до AI у мс (5000..120000), за замовчуванням 25000
# OPENAI_TIMEOUT_MS=25000
OPENAI_MODEL=
